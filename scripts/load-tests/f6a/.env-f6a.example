# Copiar a `.env-f6a` (gitignored) y completar con valores locales reales.
# k6 lee estas variables vía __ENV.NOMBRE.

BASE_URL=https://localhost:7102

# Credenciales locales — reemplazar con cuentas reales de la BD de desarrollo
DIRECTOR_DNI=12345678
DIRECTOR_PWD=
PROFESOR_DNI=87654321
PROFESOR_PWD=
ESTUDIANTE_DNI=11223344
ESTUDIANTE_PWD=

# Webhook secret (matches CrossChex:WebhookSecret en appsettings.Development.json)
CROSSCHEX_WEBHOOK_SECRET=

# Salón / sede / IDs para escenarios que mutan recursos (reemplazar con valores reales)
SALON_ID_CIERRE=1
ANIO_CIERRE=2026
MES_CIERRE=4

# Solo escenario 6 — endpoint del mock Blob (wiremock o similar)
BLOB_MOCK_ENDPOINT=http://localhost:9090/blob-mock
